FLASK_SECRET_KEY=your-secret-key-here
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── CCIC Configuration ────────────────────────────────────────────────────────
# RISK_DETECTOR: Controls which CCIC tiers are active
#   auto        → Full cascade (Tier 1 → Tier 2 → Tier 3) — use for HF Spaces
#   transformer → Tier 1 only (Legal-BERT)
#   ml          → Tier 2 only (TF-IDF+LR) — use for Vercel
#   keyword     → Tier 3 only (deterministic keyword matching)
RISK_DETECTOR=auto

# Tier 1 confidence threshold (τ_t): if calibrated confidence < this, fall to Tier 2
TRANSFORMER_THRESHOLD=0.60

# Tier 2 confidence threshold (τ_m): if ML confidence < this, fall to Tier 3
ML_RISK_THRESHOLD=0.50

# Temperature scaling factor T (Guo et al., 2017): T > 1 softens over-confident predictions
# Typical calibrated range for Legal-BERT: 1.3–2.0
CCIC_TEMPERATURE=1.5

# ── Model Paths ───────────────────────────────────────────────────────────────
TRANSFORMER_MODEL_DIR=models/transformer_risk_classifier
RISK_MODEL_PATH=models/risk_classifier.joblib

# ── Upload Limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=10485760
